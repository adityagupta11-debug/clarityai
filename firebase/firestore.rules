rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /interviews/{interviewId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // Transcript: read-only for users, written by server (Admin SDK)
      match /transcript/{docId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/interviews/$(interviewId)).data.userId == request.auth.uid;
        allow write: if false;
      }

      // Analysis: read-only for users, written by server (Admin SDK)
      match /analysis/{docId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/interviews/$(interviewId)).data.userId == request.auth.uid;
        allow write: if false;
      }
    }
  }
}
